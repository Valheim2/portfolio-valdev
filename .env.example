# ── Base de données (Turso / libSQL) ─────────────────────────────
# En local, tu peux pointer sur le fichier SQLite :
#   TURSO_DATABASE_URL="file:./prisma/dev.db"
# En production (Vercel), utilise l'URL et le token fournis par Turso :
TURSO_DATABASE_URL="libsql://ton-portfolio-xxxxx.turso.io"
TURSO_AUTH_TOKEN="ton_token_turso"

# Utilisé par les commandes Prisma CLI (db push / migrate diff).
DATABASE_URL="file:./prisma/dev.db"

# ── Espace admin ─────────────────────────────────────────────────
# Mot de passe pour accéder au panneau /admin.
ADMIN_PASSWORD="change-moi-par-un-mot-de-passe-fort"

# ── Notifications email du formulaire de contact (optionnel) ──────
# Crée une clé gratuite sur https://resend.com
# Laisser RESEND_API_KEY vide pour désactiver l'envoi d'email.
RESEND_API_KEY=""
CONTACT_EMAIL_TO="claudetsanga2@gmail.com"
CONTACT_EMAIL_FROM="Portfolio <onboarding@resend.dev>"
